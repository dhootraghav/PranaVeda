PORT=3010
SESSION_SECRET=replace-with-a-secure-random-string

# Optional SMTP settings for real email sending.
# Use either SMTP_SERVICE (for Gmail/Outlook/etc.) or SMTP_HOST/SMTP_PORT.
# If these are omitted, booking emails are saved to /email_previews locally.
SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hello@pranaveda.in
